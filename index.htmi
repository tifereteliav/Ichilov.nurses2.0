<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>אחיות פנימית איכילוב 2.0 | תפארת אליאב</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@200;400;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --astra-gold: #f0ab00;
            --astra-purple: #6b21a8;
            --ichilov-blue: #3b82f6;
            --deep-black: #000000;
        }
        body {
            font-family: 'Assistant', sans-serif;
            scroll-behavior: smooth;
            background-color: var(--deep-black);
            color: #ffffff;
            margin: 0;
            overflow-x: hidden;
        }
        
        /* Moving Ambient Glows */
        .glow-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 0;
            pointer-events: none;
        }
        .glow-blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.15;
            animation: float 20s infinite alternate ease-in-out;
        }
        .blob-1 {
            width: 50vw;
            height: 50vw;
            background: var(--astra-purple);
            top: -10%;
            left: -10%;
        }
        .blob-2 {
            width: 40vw;
            height: 40vw;
            background: var(--ichilov-blue);
            bottom: 10%;
            right: -5%;
            animation-delay: -5s;
        }
        .blob-3 {
            width: 30vw;
            height: 30vw;
            background: var(--astra-gold);
            top: 40%;
            left: 30%;
            opacity: 0.05;
            animation-duration: 25s;
        }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(10%, 15%) scale(1.1); }
        }

        .glass-card {
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover {
            border-color: rgba(240, 171, 0, 0.4);
            box-shadow: 0 0 40px rgba(107, 33, 168, 0.2);
            transform: translateY(-5px);
        }

        .nav-blur {
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Timeline flowing light effect */
        .timeline-border {
            position: relative;
        }
        .timeline-border::after {
            content: '';
            position: absolute;
            right: -2rem;
            top: 0;
            bottom: 0;
            width: 1px;
            background: rgba(255, 255, 255, 0.1);
        }
        .timeline-border.active::before {
            content: '';
            position: absolute;
            right: -2rem;
            top: 0;
            width: 1px;
            height: 100%;
            background: linear-gradient(to bottom, transparent, var(--astra-gold), var(--astra-purple), transparent);
            z-index: 1;
            animation: flowDown 3s infinite linear;
        }

        @keyframes flowDown {
            0% { transform: translateY(-100%); }
            100% { transform: translateY(100%); }
        }

        .reveal {
            opacity: 0;
            transform: translateY(15px);
            transition: all 0.7s ease-out;
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        .text-glow {
            text-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
        }
        
        .astra-gradient-text {
            background: linear-gradient(to left, #ffffff, var(--astra-gold));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body>

    <!-- Animated Background Background -->
    <div class="glow-container">
        <div class="glow-blob blob-1"></div>
        <div class="glow-blob blob-2"></div>
        <div class="glow-blob blob-3"></div>
    </div>

    <!-- Navigation -->
    <nav class="fixed top-0 w-full z-50 nav-blur py-3 px-6">
        <div class="max-w-6xl mx-auto flex items-center justify-between">
            <div class="flex items-center gap-8">
                <div class="hidden md:flex items-center gap-6 text-[10px] font-bold tracking-[0.25em] text-slate-400">
                    <a href="https://www.openevidence.com/" target="_blank" class="hover:text-white transition-colors">OPEN EVIDENCE</a>
                    <a href="https://gemini.google.com/" target="_blank" class="hover:text-white transition-colors">GEMINI</a>
                    <a href="https://notebooklm.google.com/" target="_blank" class="hover:text-white transition-colors">NOTEBOOK LM</a>
                    <a href="https://labs.google/flow" target="_blank" class="hover:text-white transition-colors">FLOW</a>
                </div>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="relative group">
                    <button class="text-white/60 hover:text-white border border-white/10 px-5 py-1.5 rounded-full text-[11px] font-bold transition-all uppercase tracking-wider">
                        כלי AI נלמדים
                    </button>
                    <div class="absolute left-0 mt-3 w-48 glass-card rounded-2xl shadow-2xl hidden group-hover:block overflow-hidden">
                        <a href="https://www.openevidence.com/" target="_blank" class="block px-5 py-3 text-sm hover:bg-white/5 border-b border-white/5">OpenEvidence</a>
                        <a href="https://gemini.google.com/" target="_blank" class="block px-5 py-3 text-sm hover:bg-white/5 border-b border-white/5">Gemini</a>
                        <a href="https://notebooklm.google.com/" target="_blank" class="block px-5 py-3 text-sm hover:bg-white/5 border-b border-white/5">NotebookLM</a>
                        <a href="https://labs.google/flow" target="_blank" class="block px-5 py-3 text-sm hover:bg-white/5">Flow</a>
                    </div>
                </div>
                <a href="https://chat.whatsapp.com/HBrXW35P06R6ozyRp3VyFa" target="_blank" class="bg-green-600 hover:bg-green-500 text-white px-5 py-1.5 rounded-full text-[11px] font-black shadow-lg transition-all flex items-center gap-2">
                    <i data-lucide="message-circle" class="w-3.5 h-3.5"></i>
                    WHATSAPP
                </a>
            </div>
        </div>
    </nav>

    <!-- Hero Section - Reduced height for better flow -->
    <section class="min-h-[70vh] flex flex-col justify-center items-center px-6 relative z-10 text-center">
        <div class="reveal active">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-slate-400 text-[9px] font-bold tracking-[0.4em] uppercase mb-6">
                Innovation • Internal Medicine Ichilov
            </div>
            <h1 class="text-5xl md:text-8xl font-black mb-6 text-white tracking-tighter text-glow leading-tight">אחיות פנימית 2.0</h1>
            <p class="text-xl md:text-2xl font-light text-slate-400 max-w-3xl mx-auto leading-relaxed mb-10">
                בינה מלאכותית כשותפה לצוות:<br>
                <span class="text-white font-bold border-b-2 border-astra-gold/50">מפתחים פתרונות, מונעים שחיקה.</span>
            </p>
            <div class="flex gap-4 justify-center">
                <a href="#schedule" class="bg-white text-black px-10 py-3 rounded-full font-black text-base hover:scale-105 transition-transform">לוח זמנים</a>
                <a href="#outcomes" class="border border-white/20 text-white px-10 py-3 rounded-full font-black text-base hover:bg-white/5 transition-all">מה מקבלים?</a>
            </div>
        </div>
    </section>

    <!-- Schedule Section - Reduced top padding -->
    <section id="schedule" class="py-16 px-6 max-w-5xl mx-auto relative z-10">
        <div class="mb-16 reveal">
            <h2 class="text-4xl font-black mb-3">לוח זמנים אינטראקטיבי</h2>
            <p class="text-slate-500 text-lg">עוברים מהכרות לביצוע - <span class="text-astra-purple">Hands-on</span></p>
        </div>

        <div class="space-y-10 pr-12">
            <!-- Step 1 -->
            <div class="reveal timeline-border group">
                <div class="absolute right-[-2.45rem] top-2 w-3.5 h-3.5 rounded-full bg-black border-2 border-astra-purple z-10 shadow-[0_0_15px_var(--astra-purple)]"></div>
                <div class="glass-card p-6 rounded-3xl">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-astra-purple font-black tracking-widest text-[10px] uppercase">SESSION 01</span>
                        <span class="text-white/40 text-xs font-bold">20 דקות</span>
                    </div>
                    <h4 class="text-xl font-bold mb-2">הרצאת השראה: מנהיגות באחיות בעידן ה-AI</h4>
                    <p class="text-slate-400 text-sm">פתיחה ומתודולוגיה לשילוב Gen AI באחיות.</p>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="reveal timeline-border group">
                <div class="absolute right-[-2.45rem] top-2 w-3.5 h-3.5 rounded-full bg-black border-2 border-slate-600 z-10"></div>
                <div class="glass-card p-6 rounded-3xl">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-slate-500 font-black tracking-widest text-[10px] uppercase">SESSION 02</span>
                        <span class="text-white/40 text-xs font-bold">30 דקות</span>
                    </div>
                    <h4 class="text-xl font-bold mb-2">צלילה לעומק: חיפוש מהימן ודיוק במידע</h4>
                    <p class="text-slate-400 text-sm italic leading-relaxed">איך לשאול שאלות נכון, מתי להסתמך על מידע ואיפה צריך להיזהר (OpenEvidence).</p>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="reveal timeline-border group">
                <div class="absolute right-[-2.45rem] top-2 w-3.5 h-3.5 rounded-full bg-black border-2 border-astra-purple z-10"></div>
                <div class="glass-card p-6 rounded-3xl">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-astra-purple font-black tracking-widest text-[10px] uppercase">SESSION 03</span>
                        <span class="text-white/40 text-xs font-bold">30 דקות</span>
                    </div>
                    <h4 class="text-xl font-bold mb-2">בניית GEMS: המומחה המחלקתי שלך</h4>
                    <p class="text-slate-400 text-sm">יצירת עוזר AI מותאם אישית לנוהל ספציפי של המחלקה.</p>
                </div>
            </div>

            <!-- Step 4 -->
            <div class="reveal timeline-border group">
                <div class="absolute right-[-2.45rem] top-2 w-3.5 h-3.5 rounded-full bg-black border-2 border-slate-600 z-10"></div>
                <div class="glass-card p-6 rounded-3xl">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-slate-500 font-black tracking-widest text-[10px] uppercase">SESSION 04</span>
                        <span class="text-white/40 text-xs font-bold">30 דקות</span>
                    </div>
                    <h4 class="text-xl font-bold mb-2">NotebookLM: הפקת תוצרי ידע</h4>
                    <p class="text-slate-400 text-sm">יצירת פודקאסטים, סיכומים ודפי עזר מתוך נהלי המחלקה.</p>
                </div>
            </div>

            <!-- Break -->
            <div class="reveal py-4 flex items-center gap-6">
                <div class="h-px bg-white/5 flex-1"></div>
                <div class="flex items-center gap-2 text-slate-600 font-black uppercase text-[10px] tracking-[0.2em]">
                    <i data-lucide="coffee" class="w-4 h-4"></i>
                    REFRESHMENT
                </div>
                <div class="h-px bg-white/5 flex-1"></div>
            </div>

            <!-- Step 5 -->
            <div class="reveal timeline-border group">
                <div class="absolute right-[-2.45rem] top-2 w-3.5 h-3.5 rounded-full bg-black border-2 border-astra-purple z-10"></div>
                <div class="glass-card p-6 rounded-3xl">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-astra-purple font-black tracking-widest text-[10px] uppercase">SESSION 05</span>
                        <span class="text-white/40 text-xs font-bold">30 דקות</span>
                    </div>
                    <h4 class="text-xl font-bold mb-2">הסינרגיה: חיבור NotebookLM ל-Gemini</h4>
                    <p class="text-slate-400 text-sm">יצירת לומדות ומשחקי למידה אינטראקטיביים דרך פונקציית ה-Canvas.</p>
                </div>
            </div>

            <!-- Step 6 -->
            <div class="reveal timeline-border group">
                <div class="absolute right-[-2.45rem] top-2 w-3.5 h-3.5 rounded-full bg-black border-2 border-slate-600 z-10"></div>
                <div class="glass-card p-6 rounded-3xl">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-slate-500 font-black tracking-widest text-[10px] uppercase">SESSION 06</span>
                        <span class="text-white/40 text-xs font-bold">30 דקות</span>
                    </div>
                    <h4 class="text-xl font-bold mb-2">Flow: יצירת סרטוני הדרכה</h4>
                    <p class="text-slate-400 text-sm italic">המחשה ויזואלית מהירה של פרוטוקולים ונהלים.</p>
                </div>
            </div>

            <!-- Final -->
            <div class="reveal group relative">
                <div class="absolute right-[-2.7rem] top-1.5 w-5 h-5 rounded-full bg-blue-600 shadow-[0_0_25px_var(--ichilov-blue)] z-10"></div>
                <div class="bg-blue-600 p-10 rounded-[2.5rem] shadow-2xl relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 blur-3xl rounded-full translate-x-1/2 -translate-y-1/2"></div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-white/60 font-black tracking-widest text-[10px] uppercase">FINALE</span>
                        <span class="text-white font-bold bg-white/10 border border-white/20 px-3 py-1 rounded-lg text-xs">30 דקות</span>
                    </div>
                    <h4 class="text-3xl font-black mb-2">סיכום והצגת תוצרים קבוצתיים</h4>
                    <p class="text-white/90 font-medium">נציגות הקבוצות מציגות פתרונות מוכנים לשימוש במחלקה.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Outcomes Section -->
    <section id="outcomes" class="py-24 px-6 relative z-10">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-4xl font-black mb-16 text-center astra-gradient-text">התוצרים שהמחלקה מקבלת</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="reveal glass-card p-8 rounded-[2rem] text-center">
                    <div class="w-12 h-12 bg-blue-500/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
                        <i data-lucide="cpu" class="w-6 h-6 text-blue-500"></i>
                    </div>
                    <h4 class="text-lg font-bold mb-2 uppercase tracking-wide">בוטים מומחים</h4>
                    <p class="text-slate-500 text-xs leading-relaxed">Gems המבוססים על נהלי איכילוב ודיוק קליני.</p>
                </div>
                <div class="reveal glass-card p-8 rounded-[2rem] text-center">
                    <div class="w-12 h-12 bg-indigo-500/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
                        <i data-lucide="mic" class="w-6 h-6 text-indigo-500"></i>
                    </div>
                    <h4 class="text-lg font-bold mb-2 uppercase tracking-wide">פודקאסטים</h4>
                    <p class="text-slate-500 text-xs leading-relaxed">סיכומי שמע חכמים ללמידה בדרכים.</p>
                </div>
                <div class="reveal glass-card p-8 rounded-[2rem] text-center">
                    <div class="w-12 h-12 bg-purple-500/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
                        <i data-lucide="layout" class="w-6 h-6 text-purple-500"></i>
                    </div>
                    <h4 class="text-lg font-bold mb-2 uppercase tracking-wide">לומדות ומשחקים</h4>
                    <p class="text-slate-500 text-xs leading-relaxed">ריענון ידע אינטראקטיבי דרך Gemini Canvas.</p>
                </div>
                <div class="reveal glass-card p-8 rounded-[2rem] text-center">
                    <div class="w-12 h-12 bg-cyan-500/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
                        <i data-lucide="eye" class="w-6 h-6 text-cyan-500"></i>
                    </div>
                    <h4 class="text-lg font-bold mb-2 uppercase tracking-wide">הנגשה ויזואלית</h4>
                    <p class="text-slate-500 text-xs leading-relaxed">סרטוני הדרכה ואינפוגרפיקות להמחשה.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer Section - Astra Style -->
    <footer class="relative bg-black pt-24 pb-12 overflow-hidden border-t border-white/5">
        
        <!-- לוגו אבסולוטי - בפינה השמאלית התחתונה -->
        <div class="absolute bottom-6 left-4 md:bottom-8 md:left-8 z-30 group">
            <div class="absolute -inset-2 bg-gradient-to-r from-astra-gold/50 to-astra-purple/50 rounded-3xl blur-xl opacity-80 group-hover:opacity-100 transition duration-500"></div>
            <div class="relative w-16 h-16 md:w-24 md:h-24 rounded-2xl overflow-hidden bg-white flex items-center justify-center p-2 md:p-3 border border-white shadow-[0_0_30px_rgba(240,171,0,0.3)] transition-transform duration-500 group-hover:scale-105">
                <img src="logo.png" alt="לוגו תפארת אליאב" class="w-full h-full object-contain">
            </div>
        </div>

        <div class="max-w-6xl mx-auto px-4 relative">
            <!-- אזור פרופיל ויצירת קשר -->
            <div class="mb-16 w-full max-w-3xl mx-auto glass-card p-10 md:p-14 rounded-[3rem] flex flex-col items-center justify-center gap-8 text-center border-white/10">
                
                <!-- תמונה במרכז -->
                <div class="relative w-32 h-32 md:w-44 md:h-44 rounded-full overflow-hidden border-4 border-astra-gold/50 shadow-[0_0_40px_rgba(240,171,0,0.2)] z-10 group">
                    <div class="absolute inset-0 bg-astra-purple/30 blur-2xl rounded-full -z-10"></div>
                    <div class="absolute inset-0 bg-slate-900 flex items-center justify-center -z-10"><i data-lucide="user" class="w-12 h-12 text-slate-700"></i></div>
                    <img src="tiferet.jpeg" alt="תפארת אליאב" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                </div>

                <!-- קישורים לרשתות -->
                <div class="w-full">
                    <h4 class="text-white font-bold mb-10 text-2xl md:text-3xl tracking-tight">תישארו מעודכנים, בואו נשמור על קשר:</h4>
                    <div class="flex justify-center gap-4 md:gap-6 flex-wrap">
                        <a href="https://tiferet-eliav.vercel.app" target="_blank" class="bg-white/5 hover:bg-white/10 border border-white/10 p-3.5 rounded-full text-slate-400 hover:text-white transition-all hover:scale-110 shadow-xl">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                        </a>
                        <a href="https://facebook.com/tiferet.eliav" target="_blank" class="bg-white/5 hover:bg-[#1877F2]/20 border border-white/10 p-3.5 rounded-full text-slate-400 hover:text-[#1877F2] transition-all hover:scale-110 shadow-xl">
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        </a>
